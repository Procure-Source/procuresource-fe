# ProcureSource environment template
#
# Copy this file to .env.local for local development.
# Never commit real credentials, tokens, private URLs, or API keys.
#
# Notes:
# - Keep parsing, OCR, database, email, and deployment keys server-side only.
# - Do not add browser-stored API keys here.
# - Keep local secrets in .env.local or your deployment platform secret store.
# - NEXT_PUBLIC_* values are exposed to the browser and must be public-safe.
# - Service role keys, JWT secrets, SMTP passwords, and API keys are server-only.
# - Rotate any credential that has ever been committed to Git history.
# - Use the production deployment dashboard for production secret values.
# - Use test credentials only in local development.
# - Leave unused optional integrations blank.
# - Keep APP_URL aligned with the environment that sends emails or webhooks.
# - Use the configured parser endpoint format expected by the runtime.
# - Use deployment/configuration names from the secret store, not user-facing model names.
# - Review this template when adding a new required environment variable.

# Admin bootstrap
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Azure Cosmos DB for MongoDB and auth
# Prefer COSMOS_MONGODB_URI for Azure-hosted environments.
COSMOS_MONGODB_URI=
MONGODB_URI=
JWT_SECRET=
JWT_EXPIRES_IN=7d
RFQ_STORE_DRIVER=local
RFQ_ALLOW_LOCAL_FALLBACK=true
RFQ_REQUIRE_CONFIGURED_STORE=false

# Azure-hosted app/runtime
PORT=8080
SERVICE_NAME=procuresource-backend
PROCURESOURCE_BACKEND_MODE=product
FRONTEND_URLS=http://localhost:3000
PROCURESOURCE_ALLOWED_ORIGINS=http://localhost:3000
REQUEST_TIMEOUT_MS=30000
HEADERS_TIMEOUT_MS=10000
KEEP_ALIVE_TIMEOUT_MS=5000
MAX_HEADERS_COUNT=80

# Optional fallback Responses-compatible parser
FALLBACK_AI_ENDPOINT=
FALLBACK_AI_DEPLOYMENT=
FALLBACK_AI_MODEL=
FALLBACK_AI_API_KEY=

# AI parsing and OCR
# Use provider-neutral names in shared templates; configure exact providers only in secret stores.
AI_PROVIDER=primary
BOQ_PARSER_ENABLED=true
BOQ_PARSER_ENDPOINT=
BOQ_PARSER_API_KEY=
BOQ_PARSER_AUTH_HEADER=Authorization
BOQ_PARSER_AUTH_SCHEME=Bearer
BOQ_PARSER_TIMEOUT_MS=25000
BOQ_API_MAX_BODY_BYTES=2097152
BOQ_MAX_TEXT_CHARS=80000
BOQ_MAX_LINE_ITEMS=120
PRIMARY_AI_API_ENDPOINT=
PRIMARY_AI_MODEL=
PRIMARY_AI_API_KEY=
AI_API_ENDPOINT=
AI_API_KEY=
AI_MODEL=
AI_API_VERSION=
PARSER_REQUEST_TIMEOUT_MS=45000
PARSE_RATE_WINDOW_MS=60000
PARSE_RATE_MAX=12
MAX_BODY_BYTES=6291456
MAX_BOQ_TEXT_CHARS=60000
MAX_DATA_URL_CHARS=5242880

# Frontend-to-backend API base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:4180
NEXT_PUBLIC_APP_URL=http://localhost:3000
STATIC_EXPORT=false

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="ProcureSource <hello@procuresource.co>"

# Application
APP_URL=http://localhost:3000

# Optional messaging integrations
WHATSAPP_BUSINESS_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCESS_TOKEN=
